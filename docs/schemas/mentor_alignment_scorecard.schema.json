{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipnl-paper-pilot.local/schemas/mentor_alignment_scorecard.schema.json",
  "title": "Mentor Alignment Scorecard",
  "description": "Post-revision evaluation scorecard.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "draft_id",
    "dimensions",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "draft_id": {
      "type": "string"
    },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "before",
          "after",
          "delta"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "before": {
            "type": "number"
          },
          "after": {
            "type": "number"
          },
          "delta": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "remaining_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
