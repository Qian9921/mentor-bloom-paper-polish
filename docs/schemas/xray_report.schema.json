{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipnl-paper-pilot.local/schemas/xray_report.schema.json",
  "title": "Paper Xray Report",
  "description": "Structured diagnosis report for a mature draft.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "draft_id",
    "overall_summary",
    "dimensions",
    "findings",
    "prioritized_actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "draft_id": {
      "type": "string"
    },
    "overall_summary": {
      "type": "string"
    },
    "overall_risk_level": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "dimensions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "score",
          "summary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "mentor-drift",
              "ai-smell",
              "terminology-risk",
              "claim-precision",
              "transition-rhythm",
              "paragraph-architecture",
              "evidence-language-gap",
              "truth-risk-lite"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "dimension",
          "severity",
          "issue",
          "evidence",
          "recommended_action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "dimension": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "section_id": {
            "type": "string"
          },
          "paragraph_id": {
            "type": "string"
          },
          "issue": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          },
          "do_not_break": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "prioritized_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "title",
          "rationale"
        ],
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "linked_findings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
