{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipnl-paper-pilot.local/schemas/mentor_material_manifest.schema.json",
  "title": "Mentor Material Manifest",
  "description": "Normalized inventory of mentor-side source materials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "mentor_id",
    "root_dir",
    "summary",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mentor_id": {
      "type": "string",
      "minLength": 1
    },
    "root_dir": {
      "type": "string",
      "minLength": 1
    },
    "lab_domain": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_count",
        "by_material_type",
        "by_trust_tier"
      ],
      "properties": {
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "by_material_type": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "by_trust_tier": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "filename",
          "extension",
          "sha256",
          "bytes",
          "material_type",
          "source_type",
          "trust_tier",
          "language",
          "mtime"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "material_type": {
            "type": "string",
            "enum": [
              "paper",
              "revision_trace",
              "chat",
              "transcript",
              "comment",
              "reference",
              "slide",
              "notes",
              "other"
            ]
          },
          "source_type": {
            "type": "string",
            "enum": [
              "mentor_authored",
              "mentor_edited",
              "mentor_spoken",
              "external_reference",
              "student_authored",
              "unknown"
            ]
          },
          "trust_tier": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "language": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "mtime": {
            "type": "string",
            "format": "date-time"
          },
          "title_guess": {
            "type": "string"
          },
          "source_notes": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
