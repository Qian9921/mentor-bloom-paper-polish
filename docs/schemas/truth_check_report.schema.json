{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipnl-paper-pilot.local/schemas/truth_check_report.schema.json",
  "title": "Truth Check Lite Report",
  "description": "Risk report for claim/evidence drift and scientific-overclaim risk.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "draft_id",
    "overall_risk_level",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "draft_id": {
      "type": "string"
    },
    "overall_risk_level": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "risk_type",
          "evidence",
          "recommended_action"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "risk_type": {
            "type": "string"
          },
          "section_id": {
            "type": "string"
          },
          "paragraph_id": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          }
        }
      }
    }
  }
}
