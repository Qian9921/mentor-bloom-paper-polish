{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipnl-paper-pilot.local/schemas/project_fact_sheet.schema.json",
  "title": "Project Fact Sheet",
  "description": "Lightweight project-context artifact used to guard scientific meaning during revision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "draft_id",
    "problem_signals",
    "method_signals",
    "evidence_signals",
    "do_not_break_constraints"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "draft_id": {
      "type": "string"
    },
    "problem_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "method_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contribution_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "terminology_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "do_not_break_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
